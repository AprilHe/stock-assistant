# LLM — LLM_MODEL is optional.
# If omitted, the model is auto-selected from whichever API key is set below:
#   GEMINI_API_KEY      → gemini/gemini-2.0-flash
#   ANTHROPIC_API_KEY   → claude-haiku-4-5-20251001
#   OPENAI_API_KEY      → gpt-4o-mini
#   GROQ_API_KEY        → groq/llama-3.3-70b-versatile
#
# To override the auto-selected model, uncomment one line:
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_MODEL=anthropic/claude-sonnet-4-6
# LLM_MODEL=gpt-4o
# LLM_MODEL=groq/llama-3.3-70b-versatile

# API Keys — fill in only the provider you are using
# GEMINI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# GROQ_API_KEY=your_key_here

# Free-tier rate limit guard
# Set to 4 when using Gemini or Groq free tiers (~15 RPM limit).
# LLM_REQUEST_DELAY_S=4

# News
NEWS_API_KEY=your_key_here

# Telegram — optional. Remove or leave commented out to skip Telegram delivery.
# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
