# LLM — pick one provider, comment out the others
LLM_MODEL=gemini/gemini-1.5-flash              # Google (free)
# LLM_MODEL=anthropic/claude-sonnet-4-6        # Anthropic
# LLM_MODEL=gpt-4o                             # OpenAI
# LLM_MODEL=groq/llama-3.3-70b-versatile       # Groq (free, fast)

# API Keys — only fill in the ones you're using
GEMINI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GROQ_API_KEY=your_key_here

# News
NEWS_API_KEY=your_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
